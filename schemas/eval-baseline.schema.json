{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/s977043/plangate/schemas/eval-baseline.schema.json",
  "title": "PlanGate Eval Baseline Snapshot",
  "description": "Frozen baseline of bin/plangate eval results across representative TASKs. Generated by scripts/baseline-snapshot.py and stored under docs/ai/eval-baselines/. Privacy: docs/ai/metrics-privacy.md §3 Allowed only — no file paths, command outputs, prompts, or other §4 Forbidden fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseline_id",
    "evaluated_at",
    "release",
    "evaluator_version",
    "tasks",
    "aggregate"
  ],
  "properties": {
    "baseline_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}(-[a-z0-9-]+)?$",
      "description": "Date-based identifier (YYYY-MM-DD or YYYY-MM-DD-suffix)"
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "release": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "PlanGate release at the time of baseline (e.g. v8.5.0)"
    },
    "evaluator_version": {
      "type": "string",
      "description": "scripts/eval-runner.py version (EVAL_RUNNER_VERSION)"
    },
    "plangate_cli_version": {
      "type": "string",
      "description": "bin/plangate PLANGATE_VERSION at baseline time (optional)"
    },
    "host_os": {
      "type": "string",
      "description": "Host platform identifier (e.g. darwin-25.4.0). No PII / IP / hostname allowed."
    },
    "profile": {
      "type": ["string", "null"],
      "description": "Model profile key (or null if unspecified)"
    },
    "session_log_supplied": {
      "type": "boolean"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_count"],
      "properties": {
        "task_count": { "type": "integer", "minimum": 1 },
        "ac_coverage_avg_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "format_adherence_pass_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "scope_discipline_pass_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "verification_honesty_pass_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "stop_behavior_pass_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "approval_discipline_pass_rate_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "release_blocker_total": { "type": "integer", "minimum": 0 },
        "release_blocker_unique_aspects": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "ac_coverage_pct"],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^TASK-[0-9]{4}$"
        },
        "ac_coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "approval_discipline": { "$ref": "#/$defs/verdictOrNa" },
        "format_adherence": { "$ref": "#/$defs/verdictOrNa" },
        "scope_discipline": { "$ref": "#/$defs/verdictOrNa" },
        "verification_honesty": { "$ref": "#/$defs/verdictOrNa" },
        "stop_behavior": { "$ref": "#/$defs/verdictOrNa" },
        "tool_overuse": { "$ref": "#/$defs/verdictOrNa" },
        "latency_cost": { "$ref": "#/$defs/verdictOrNa" },
        "release_blocker_count": { "type": "integer", "minimum": 0 },
        "release_blocker_aspects": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "verdictOrNa": {
      "type": "string",
      "enum": ["PASS", "FAIL", "WARN", "n/a"]
    }
  }
}
